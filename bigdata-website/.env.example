# Configuración de Entorno (Ejemplo)
# Copia este archivo a .env y ajusta los valores

# VULTR API (Credenciales)
VULTR_API_KEY=NNWLHLEV4KOL5UGIB4KF4DPKD5ECYWCU6REQ

# N8N URLs
# En LOCAL (Chromebook): Usa https://n8n.bigdata.net.co/...
# En VPS (Producción): Usa http://n8n:5678/... (para red interna)
N8N_WEBHOOK_URL=https://n8n.bigdata.net.co/webhook/bigdata-lead-vps
N8N_VALIDATE_URL=https://n8n.bigdata.net.co/webhook/verify-code

# Puertos
# Puerto externo para la API (Evita conflicto con 3000)
API_PORT=3005

# Configuración de Red Docker
# Nombre de la red externa donde está Traefik (y N8N en el VPS)
TRAEFIK_NETWORK=n8n-automation_default

# Configuración SSL Traefik
# En Prod: letsencrypt
# En Dev: staging (o comentar si no usas Traefik local)
TRAEFIK_CERTRESOLVER=letsencrypt
