# ============================================
# BigCloudMiami - Backend Environment Example
# ============================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a git.

NODE_ENV=development

# ---- JWT ----
# Secreto para firmar tokens JWT. Usa una cadena larga y aleatoria.
JWT_SECRET=genera_un_secreto_largo_aqui
JWT_EXPIRES=1d

# ---- PostgreSQL ----
POSTGRES_HOST=postgres-shared
POSTGRES_PORT=5432
POSTGRES_DB=bigdata_isp_v2
POSTGRES_USER=admin
POSTGRES_PASSWORD=tu_password_de_postgres

# ---- Proxmox ----
PROXMOX_HOST=IP_DEL_SERVIDOR_PROXMOX
PROXMOX_PORT=8006
PROXMOX_NODE=nombre_del_nodo
PROXMOX_USER=usuario@pve
PROXMOX_TOKEN_ID=nombre_del_token
PROXMOX_TOKEN_SECRET=uuid_del_token_secreto
# false en desarrollo, true en producción con certificado válido
PROXMOX_REJECT_UNAUTHORIZED=false

# ---- n8n Webhooks ----
N8N_WEBHOOK_LEAD=https://n8n.tudominio.com/webhook/bigdata-lead-vps
N8N_WEBHOOK_BACKUP=https://n8n.tudominio.com/webhook/backup-alerts

# ---- Wompi (Pagos) ----
# Obtener en: https://dashboard.wompi.co → Desarrolladores → Llaves API
WOMPI_PUBLIC_KEY=pub_test_...
WOMPI_PRIVATE_KEY=prv_test_...
WOMPI_EVENTS_SECRET=...
WOMPI_INTEGRITY_SECRET=...
WOMPI_WEBHOOK_URL=https://tudominio.com/api/payment/webhook

# ---- Conversión de moneda ----
USD_TO_COP_RATE=4200

# ---- Vultr (VPS externo del frontend) ----
VULTR_API_KEY=tu_api_key_de_vultr

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_GENERAL=100
RATE_LIMIT_MAX_LOGIN=10

# ============================================
# NOTAS PARA PRODUCCIÓN:
# - Cambiar PROXMOX_REJECT_UNAUTHORIZED=true
# - Usar secretos de Docker Secrets o Vault en vez de .env
# - Rotar PROXMOX_TOKEN_SECRET periódicamente
# - JWT_SECRET debe ser al menos 32 chars aleatorios
# ============================================
