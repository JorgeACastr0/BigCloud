# BigCloudMiami - Variables de entorno para sistema de backup
# Copia este archivo como .env y rellena los valores

# Directorio donde se guardan los backups
BACKUP_DIR=/opt/bigcloud-backups

# Días de retención de backups diarios
BACKUP_RETENTION_DAYS=7

# Directorio del proyecto
PROJECT_DIR=/opt/bigcloud

# Directorio de datos de n8n
N8N_DATA_DIR=/opt/bigcloud/n8n-automation/n8n-data

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=TU_PASSWORD_AQUI

# Proxmox (mismo que el backend)
PROXMOX_HOST=201.184.49.203
PROXMOX_PORT=8006
PROXMOX_NODE=servidor1
PROXMOX_USER=api-user@pve
PROXMOX_TOKEN_ID=mi-token
PROXMOX_TOKEN_SECRET=TU_TOKEN_SECRETO

# Webhook de n8n para notificaciones de backup
N8N_WEBHOOK_BACKUP=https://n8n.bigdata.net.co/webhook/backup-alerts
